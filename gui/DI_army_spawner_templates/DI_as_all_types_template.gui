types DI_Army_Spawner_Types
{
    type DI_army_spawner_vbox = vbox
    {
        layoutpolicy_horizontal = expanding
        layoutpolicy_vertical = expanding

        datacontext = "[MenAtArmsType]"
        block "visible_when"
        {
            visible = "[GetVariableSystem.HasValue( 'army_spawner_tab', MenAtArmsType.GetBaseTypeName )]"
        }

        button_standard = {
            block "on_add" {}

            layoutpolicy_horizontal = expanding
            size = { 300 55 }

            hbox = {
                margin = { 5 0 }
                margin_right = 10
                spacing = 10

                icon = {
                    size = { 35 35 }
                    texture = "[MenAtArmsType.GetIcon]"
                }

                text_single = {
                    # layoutpolicy_horizontal = expanding
                    text = "[MenAtArmsType.GetName]"
                    default_format = "#clickable"
                }

                expand = {}

            }
        }
    }
}
